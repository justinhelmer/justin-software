---
/**
 * Keyboard navigation controller.
 *
 * The site is a 2D grid:
 *   horizontal axis = top-level pages (home → about → writing → links)
 *   vertical axis   = items within a page (posts, links)
 *
 * ← / →   move between pages (always, regardless of selection)
 * ↑ / ↓   move between items on the current page
 * Enter    open the selected item (drills in)
 * Escape   clear selection / go back to parent
 *
 * Pages declare their items with `data-nav-item` on any <a> element.
 * This is the only contract — no class names, no element structure.
 * As the site grows, just add `data-nav-item` to new navigable elements.
 */
---

<script>
  const PAGE_ORDER = ['/', '/about', '/writing', '/links'];

  function isInputFocused(): boolean {
    const el = document.activeElement;
    return el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement;
  }

  function isPaletteOpen(): boolean {
    return document.getElementById('shell-palette')?.getAttribute('aria-hidden') === 'false';
  }

  function isHelpOpen(): boolean {
    return document.getElementById('help-overlay')?.getAttribute('aria-hidden') === 'false';
  }

  // ── Page index ────────────────────────────────────────────────

  function getPageIndex(path: string): number {
    const exact = PAGE_ORDER.indexOf(path);
    if (exact !== -1) return exact;
    for (let i = PAGE_ORDER.length - 1; i >= 0; i--) {
      if (path.startsWith(PAGE_ORDER[i]) && PAGE_ORDER[i] !== '/') return i;
    }
    return 0;
  }

  function goToPage(index: number) {
    const target = PAGE_ORDER[index];
    if (!target) return;
    const current = getPageIndex(window.location.pathname);
    if (index === current && window.location.pathname === target) return;
    document.documentElement.dataset.navDirection = index > current ? 'forward' : 'back';
    // Use Astro's navigate for proper View Transition support
    const nav = (window as any).__astro_navigate;
    if (nav) nav(target);
    else window.location.href = target;
  }

  // ── Item selection ────────────────────────────────────────────

  function getItems(): HTMLAnchorElement[] {
    return Array.from(document.querySelectorAll('[data-nav-item]'));
  }

  function getSelected(items: HTMLAnchorElement[]): number {
    return items.findIndex(el => el.hasAttribute('data-nav-selected'));
  }

  function selectItem(items: HTMLAnchorElement[], index: number) {
    items.forEach(el => el.removeAttribute('data-nav-selected'));
    if (index >= 0 && index < items.length) {
      items[index].setAttribute('data-nav-selected', '');
      items[index].scrollIntoView({ block: 'nearest' });
    }
  }

  function clearSelection() {
    document.querySelectorAll('[data-nav-selected]').forEach(el => el.removeAttribute('data-nav-selected'));
  }

  // ── Keyboard handler ──────────────────────────────────────────

  document.addEventListener('keydown', (e) => {
    if (isInputFocused() || isPaletteOpen() || isHelpOpen()) return;

    const items = getItems();
    const sel = getSelected(items);
    const pageIdx = getPageIndex(window.location.pathname);

    switch (e.key) {
      case 'ArrowRight':
        e.preventDefault();
        if (pageIdx < PAGE_ORDER.length - 1) goToPage(pageIdx + 1);
        break;

      case 'ArrowLeft':
        e.preventDefault();
        if (pageIdx > 0) goToPage(pageIdx - 1);
        break;

      case 'ArrowDown':
        if (items.length === 0) break;
        e.preventDefault();
        selectItem(items, sel < items.length - 1 ? sel + 1 : 0);
        break;

      case 'ArrowUp':
        if (items.length === 0) break;
        e.preventDefault();
        selectItem(items, sel > 0 ? sel - 1 : items.length - 1);
        break;

      case 'Enter':
        if (sel >= 0) {
          e.preventDefault();
          items[sel].click();
        }
        break;

      case 'Escape':
        if (sel >= 0) {
          e.preventDefault();
          clearSelection();
        }
        break;

      case 'Backspace':
        // Go back to the parent page (e.g. /writing/post → /writing)
        if (window.location.pathname !== PAGE_ORDER[pageIdx]) {
          e.preventDefault();
          goToPage(pageIdx);
        }
        break;
    }
  });

  // Clear selection on page transition
  document.addEventListener('astro:after-swap', clearSelection);
</script>
