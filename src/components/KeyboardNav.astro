---
/**
 * Keyboard navigation.
 *
 * Horizontal axis: all [data-nav-bar] elements in the header
 *   (nav links + theme toggle). Arrow right/left traverses them.
 *   Enter on a link navigates. Enter on a button activates it.
 *
 * Vertical axis: [data-nav-item] elements on the current page.
 *   Arrow up/down selects. Enter opens.
 */
---

<script>
  function blocked(): boolean {
    const active = document.activeElement;
    if (active instanceof HTMLInputElement || active instanceof HTMLTextAreaElement) return true;
    if (document.getElementById('shell-palette')?.getAttribute('aria-hidden') === 'false') return true;
    if (document.getElementById('help-overlay')?.getAttribute('aria-hidden') === 'false') return true;
    return false;
  }

  // ── Horizontal: nav bar items ─────────────────────────────────

  function getBarItems(): HTMLElement[] {
    return Array.from(document.querySelectorAll('[data-nav-bar]'));
  }

  function currentBarIndex(): number {
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    const items = getBarItems();
    // Find active nav link by href match
    for (let i = 0; i < items.length; i++) {
      const href = items[i].getAttribute('href');
      if (href === path) return i;
      if (href && href !== '/' && path.startsWith(href)) return i;
    }
    return -1; // on home (before first nav link)
  }

  function activateBarItem(index: number) {
    const items = getBarItems();
    if (index < 0 || index >= items.length) return;
    const el = items[index];
    // If it's a link, click it (navigates via ClientRouter)
    if (el instanceof HTMLAnchorElement) {
      el.click();
    } else {
      // It's a button (theme toggle etc.) — click it
      el.click();
    }
  }

  // ── Vertical: page items ──────────────────────────────────────

  function getPageItems(): HTMLAnchorElement[] {
    return Array.from(document.querySelectorAll('[data-nav-item]'));
  }

  function selectedIndex(list: HTMLElement[]): number {
    return list.findIndex(el => el.hasAttribute('data-nav-selected'));
  }

  function select(list: HTMLElement[], i: number) {
    list.forEach(el => el.removeAttribute('data-nav-selected'));
    if (i >= 0 && i < list.length) {
      list[i].setAttribute('data-nav-selected', '');
      list[i].scrollIntoView({ block: 'nearest' });
    }
  }

  function clearSelection() {
    document.querySelectorAll('[data-nav-selected]').forEach(el =>
      el.removeAttribute('data-nav-selected')
    );
  }

  // ── Keyboard handler ──────────────────────────────────────────

  document.addEventListener('keydown', (e) => {
    if (blocked()) return;

    const barItems = getBarItems();
    const barIdx = currentBarIndex();
    const pageItems = getPageItems();
    const sel = selectedIndex(pageItems);

    switch (e.key) {
      case 'ArrowRight':
        e.preventDefault();
        if (barIdx < barItems.length - 1) {
          activateBarItem(barIdx + 1);
        }
        break;

      case 'ArrowLeft':
        e.preventDefault();
        if (barIdx > 0) {
          activateBarItem(barIdx - 1);
        } else if (barIdx === 0) {
          // Go home
          const mark = document.querySelector('header a[href="/"]') as HTMLAnchorElement | null;
          if (mark) mark.click();
        }
        break;

      case 'ArrowDown':
        if (!pageItems.length) break;
        e.preventDefault();
        if (sel < pageItems.length - 1) select(pageItems, sel + 1);
        else if (sel === -1) select(pageItems, 0);
        break;

      case 'ArrowUp':
        if (!pageItems.length) break;
        e.preventDefault();
        if (sel > 0) select(pageItems, sel - 1);
        else if (sel === -1) select(pageItems, pageItems.length - 1);
        break;

      case 'Enter':
        if (sel >= 0 && pageItems[sel]) {
          const href = (pageItems[sel] as HTMLAnchorElement).getAttribute('href') || '';
          if (!href.startsWith('http') && !href.startsWith('mailto:')) e.preventDefault();
          pageItems[sel].click();
        }
        break;

      case 'Escape':
        if (sel >= 0) { e.preventDefault(); clearSelection(); }
        break;

      case 'Backspace': {
        const path = window.location.pathname.replace(/\/$/, '') || '/';
        const parentHref = barItems[barIdx]?.getAttribute('href');
        if (parentHref && path !== parentHref) {
          e.preventDefault();
          activateBarItem(barIdx);
        }
        break;
      }
    }
  });

  document.addEventListener('astro:after-swap', clearSelection);
</script>
