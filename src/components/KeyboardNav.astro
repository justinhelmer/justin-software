---
/**
 * Keyboard navigation — reads page structure from the actual nav links.
 *
 *   ← / →     traverse pages (clicks the real nav <a> elements)
 *   ↑ / ↓     select items within the current page
 *   Enter      open selected item
 *   Escape     clear selection
 *   Backspace  back to parent page
 */
---

<script>
  function blocked(): boolean {
    const active = document.activeElement;
    if (active instanceof HTMLInputElement || active instanceof HTMLTextAreaElement) return true;
    if (document.getElementById('shell-palette')?.getAttribute('aria-hidden') === 'false') return true;
    if (document.getElementById('help-overlay')?.getAttribute('aria-hidden') === 'false') return true;
    return false;
  }

  function getNavLinks(): HTMLAnchorElement[] {
    return Array.from(document.querySelectorAll('header nav a[href]'));
  }

  function currentNavIndex(): number {
    const path = window.location.pathname.replace(/\/$/, '') || '/';
    const links = getNavLinks();
    // Check for exact match on nav links
    for (let i = 0; i < links.length; i++) {
      if (links[i].getAttribute('href') === path) return i;
    }
    // Check for prefix match (e.g. /writing/post → /writing)
    for (let i = links.length - 1; i >= 0; i--) {
      const href = links[i].getAttribute('href') || '';
      if (href !== '/' && path.startsWith(href)) return i;
    }
    // On home page → return -1 (before the first nav link)
    return -1;
  }

  function clickNavLink(index: number) {
    const links = getNavLinks();
    if (index >= 0 && index < links.length) {
      links[index].click();
    }
  }

  function goHome() {
    const mark = document.querySelector('header a[href="/"]') as HTMLAnchorElement | null;
    if (mark) mark.click();
  }

  function items(): HTMLAnchorElement[] {
    return Array.from(document.querySelectorAll('[data-nav-item]'));
  }

  function selected(list: HTMLAnchorElement[]): number {
    return list.findIndex(el => el.hasAttribute('data-nav-selected'));
  }

  function select(list: HTMLAnchorElement[], i: number) {
    list.forEach(el => el.removeAttribute('data-nav-selected'));
    if (i >= 0 && i < list.length) {
      list[i].setAttribute('data-nav-selected', '');
      list[i].scrollIntoView({ block: 'nearest' });
    }
  }

  function clearSelection() {
    document.querySelectorAll('[data-nav-selected]').forEach(el =>
      el.removeAttribute('data-nav-selected')
    );
  }

  document.addEventListener('keydown', (e) => {
    if (blocked()) return;

    const navLinks = getNavLinks();
    const navIdx = currentNavIndex();
    const list = items();
    const sel = selected(list);

    switch (e.key) {
      case 'ArrowRight':
        e.preventDefault();
        if (navIdx < navLinks.length - 1) {
          clickNavLink(navIdx + 1);
        }
        break;

      case 'ArrowLeft':
        e.preventDefault();
        if (navIdx > 0) {
          clickNavLink(navIdx - 1);
        } else if (navIdx === 0) {
          goHome();
        }
        break;

      case 'ArrowDown':
        if (!list.length) break;
        e.preventDefault();
        if (sel < list.length - 1) select(list, sel + 1);
        else if (sel === -1) select(list, 0);
        break;

      case 'ArrowUp':
        if (!list.length) break;
        e.preventDefault();
        if (sel > 0) select(list, sel - 1);
        else if (sel === -1) select(list, list.length - 1);
        break;

      case 'Enter':
        if (sel >= 0 && list[sel]) {
          const href = list[sel].getAttribute('href') || '';
          if (!href.startsWith('http') && !href.startsWith('mailto:')) e.preventDefault();
          list[sel].click();
        }
        break;

      case 'Escape':
        if (sel >= 0) { e.preventDefault(); clearSelection(); }
        break;

      case 'Backspace': {
        // If on a sub-page (e.g. /writing/post), go to its parent nav link
        const path = window.location.pathname.replace(/\/$/, '') || '/';
        const parentHref = navLinks[navIdx]?.getAttribute('href');
        if (parentHref && path !== parentHref) {
          e.preventDefault();
          clickNavLink(navIdx);
        }
        break;
      }
    }
  });

  document.addEventListener('astro:after-swap', clearSelection);
</script>
