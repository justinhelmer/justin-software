---
/**
 * Keyboard navigation — driven by the actual nav links in the DOM.
 *
 * Instead of a hardcoded PAGE_ORDER, this reads the nav links from
 * the header and uses them as the navigation structure. The DOM is
 * the source of truth — if a link is in the nav, it's navigable.
 *
 *   ← / →     traverse nav links (page-level)
 *   ↑ / ↓     select items within the current page
 *   Enter      open selected item
 *   Escape     clear selection
 *   Backspace  go back to parent page
 */
---

<script>
  function blocked(): boolean {
    const active = document.activeElement;
    if (active instanceof HTMLInputElement || active instanceof HTMLTextAreaElement) return true;
    if (document.getElementById('shell-palette')?.getAttribute('aria-hidden') === 'false') return true;
    if (document.getElementById('help-overlay')?.getAttribute('aria-hidden') === 'false') return true;
    return false;
  }

  /** Read the navigation structure from the actual nav links in the DOM. */
  function getNavPages(): string[] {
    const links = document.querySelectorAll('header nav a[href]');
    // Home (/) is always the implicit first — it's the mark link, not in nav
    const pages = ['/'];
    links.forEach(a => {
      const href = (a as HTMLAnchorElement).getAttribute('href');
      if (href && !pages.includes(href)) pages.push(href);
    });
    return pages;
  }

  /** Normalize path by stripping trailing slash (except root). */
  function norm(path: string): string {
    if (path === '/') return path;
    return path.replace(/\/$/, '');
  }

  /** Find current page index in nav order. Handles sub-pages. */
  function currentIndex(pages: string[]): number {
    const path = norm(window.location.pathname);
    const exact = pages.indexOf(path);
    if (exact !== -1) return exact;
    // Sub-page: /writing/hello-world → /writing
    for (let i = pages.length - 1; i >= 0; i--) {
      if (path.startsWith(pages[i]) && pages[i] !== '/') return i;
    }
    return 0;
  }

  function navigate(path: string) {
    if (norm(window.location.pathname) === norm(path)) return;
    const nav = (window as any).__astro_navigate;
    if (nav) nav(path);
    else window.location.href = path;
  }

  // ── Item selection ────────────────────────────────────────────

  function items(): HTMLAnchorElement[] {
    return Array.from(document.querySelectorAll('[data-nav-item]'));
  }

  function selected(list: HTMLAnchorElement[]): number {
    return list.findIndex(el => el.hasAttribute('data-nav-selected'));
  }

  function select(list: HTMLAnchorElement[], i: number) {
    list.forEach(el => el.removeAttribute('data-nav-selected'));
    if (i >= 0 && i < list.length) {
      list[i].setAttribute('data-nav-selected', '');
      list[i].scrollIntoView({ block: 'nearest' });
    }
  }

  function clearSelection() {
    document.querySelectorAll('[data-nav-selected]').forEach(el =>
      el.removeAttribute('data-nav-selected')
    );
  }

  // ── Keyboard handler ──────────────────────────────────────────

  document.addEventListener('keydown', (e) => {
    if (blocked()) return;

    const pages = getNavPages();
    const idx = currentIndex(pages);
    const list = items();
    const sel = selected(list);

    switch (e.key) {
      case 'ArrowRight':
        if (idx < pages.length - 1) {
          e.preventDefault();
          navigate(pages[idx + 1]);
        }
        break;

      case 'ArrowLeft':
        if (idx > 0) {
          e.preventDefault();
          navigate(pages[idx - 1]);
        }
        break;

      case 'ArrowDown':
        if (!list.length) break;
        e.preventDefault();
        if (sel < list.length - 1) select(list, sel + 1);
        else if (sel === -1) select(list, 0);
        break;

      case 'ArrowUp':
        if (!list.length) break;
        e.preventDefault();
        if (sel > 0) select(list, sel - 1);
        else if (sel === -1) select(list, list.length - 1);
        break;

      case 'Enter':
        if (sel >= 0 && list[sel]) {
          const href = list[sel].getAttribute('href') || '';
          if (!href.startsWith('http') && !href.startsWith('mailto:')) e.preventDefault();
          list[sel].click();
        }
        break;

      case 'Escape':
        if (sel >= 0) { e.preventDefault(); clearSelection(); }
        break;

      case 'Backspace': {
        const parentPage = pages[idx];
        if (parentPage && norm(window.location.pathname) !== norm(parentPage)) {
          e.preventDefault();
          navigate(parentPage);
        }
        break;
      }
    }
  });

  document.addEventListener('astro:after-swap', clearSelection);
</script>
