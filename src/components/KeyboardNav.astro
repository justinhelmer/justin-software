---
/**
 * Keyboard navigation controller.
 *
 *   ← / →     pages (home → about → writing → links)
 *   ↑ / ↓     items within the current page
 *   Enter      open selected item
 *   Escape     clear selection
 *   Backspace  go back to parent page
 *
 * Pages mark navigable items with `data-nav-item` on <a> elements.
 * Selection is indicated by `data-nav-selected` (styled in global.css).
 */
---

<script>
  const PAGE_ORDER = ['/', '/about', '/writing', '/links'];

  function blocked(): boolean {
    const active = document.activeElement;
    const inputFocused = active instanceof HTMLInputElement || active instanceof HTMLTextAreaElement;
    const paletteOpen = document.getElementById('shell-palette')?.getAttribute('aria-hidden') === 'false';
    const helpOpen = document.getElementById('help-overlay')?.getAttribute('aria-hidden') === 'false';
    return inputFocused || paletteOpen || helpOpen;
  }

  function pageIndex(path: string): number {
    const exact = PAGE_ORDER.indexOf(path);
    if (exact !== -1) return exact;
    for (let i = PAGE_ORDER.length - 1; i >= 0; i--) {
      if (path.startsWith(PAGE_ORDER[i]) && PAGE_ORDER[i] !== '/') return i;
    }
    return 0;
  }

  function goToPage(index: number) {
    const target = PAGE_ORDER[index];
    if (!target) return;
    const nav = (window as any).__astro_navigate;
    if (nav) nav(target);
    else window.location.href = target;
  }

  function items(): HTMLAnchorElement[] {
    return Array.from(document.querySelectorAll('[data-nav-item]'));
  }

  function selected(list: HTMLAnchorElement[]): number {
    return list.findIndex(el => el.hasAttribute('data-nav-selected'));
  }

  function select(list: HTMLAnchorElement[], i: number) {
    list.forEach(el => el.removeAttribute('data-nav-selected'));
    if (i >= 0 && i < list.length) {
      list[i].setAttribute('data-nav-selected', '');
      list[i].scrollIntoView({ block: 'nearest' });
    }
  }

  function clearSelection() {
    document.querySelectorAll('[data-nav-selected]').forEach(el => el.removeAttribute('data-nav-selected'));
  }

  document.addEventListener('keydown', (e) => {
    if (blocked()) return;

    const list = items();
    const sel = selected(list);
    const idx = pageIndex(window.location.pathname);

    switch (e.key) {
      case 'ArrowRight':
        e.preventDefault();
        if (idx < PAGE_ORDER.length - 1) goToPage(idx + 1);
        break;

      case 'ArrowLeft':
        e.preventDefault();
        if (idx > 0) goToPage(idx - 1);
        break;

      case 'ArrowDown':
        if (!list.length) break;
        e.preventDefault();
        if (sel < list.length - 1) select(list, sel + 1);
        else if (sel === -1) select(list, 0);
        break;

      case 'ArrowUp':
        if (!list.length) break;
        e.preventDefault();
        if (sel > 0) select(list, sel - 1);
        else if (sel === -1) select(list, list.length - 1);
        break;

      case 'Enter':
        if (sel >= 0 && list[sel]) {
          const href = list[sel].getAttribute('href') || '';
          const external = href.startsWith('http') || href.startsWith('mailto:');
          if (!external) e.preventDefault();
          list[sel].click();
        }
        break;

      case 'Escape':
        if (sel >= 0) { e.preventDefault(); clearSelection(); }
        break;

      case 'Backspace':
        if (window.location.pathname !== PAGE_ORDER[idx]) {
          e.preventDefault();
          goToPage(idx);
        }
        break;
    }
  });

  document.addEventListener('astro:after-swap', clearSelection);
</script>
