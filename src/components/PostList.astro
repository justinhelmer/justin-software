---
import { formatDate, latestPosts } from '../lib/config';

interface Post {
  id: string;
  data: {
    title: string;
    date: Date;
  };
}

interface Props {
  posts: Post[];
  limit?: number;
}

const { posts, limit } = Astro.props;

const sorted = latestPosts(posts, limit);
---

<ul class="post-list" role="list">
  {sorted.map(post => (
    <li class="list-row">
      <a href={`/writing/${post.id}`} class="post-link list-link" data-nav-item data-post-id={post.id}>
        <span class="post-title">{post.data.title}</span>
        <span class="post-date mono-date">{formatDate(post.data.date)}</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .post-list {
    list-style: none;
  }

  .post-title {
    font-size: 14px;
    color: var(--text-link);
  }

  .post-link:hover .post-title,
  .post-link[data-nav-selected] .post-title {
    color: var(--text);
  }
</style>
