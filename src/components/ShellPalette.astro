---
import { getCollection } from 'astro:content';

const posts = await getCollection('writing');
const siteData = {
  routes: [
    { path: '/', label: 'home', type: 'page' },
    { path: '/about', label: 'about', type: 'page' },
    { path: '/writing', label: 'writing', type: 'page' },
    { path: '/links', label: 'links', type: 'page' },
    ...posts.map(p => ({
      path: `/writing/${p.id}`,
      label: p.data.title,
      type: 'post',
    })),
  ],
};
---

<script type="application/json" id="shell-data" set:html={JSON.stringify(siteData)} />

<div id="shell-palette" class="palette-overlay" aria-hidden="true">
  <div class="palette-backdrop"></div>
  <div class="palette-container">
    <div class="palette-input-row">
      <span class="prompt">
        <span class="prompt-dir">~/justin.software</span>
        <span class="prompt-arrow">❯</span>
      </span>
      <input
        id="palette-input"
        class="palette-input"
        type="text"
        autocomplete="off"
        spellcheck="false"
      />
    </div>
    <div id="palette-completions" class="palette-completions"></div>
    <div class="palette-hint">
      <span><kbd>tab</kbd> complete</span>
      <span><kbd>↑↓</kbd> select</span>
      <span><kbd>↵</kbd> run</span>
      <span><kbd>esc</kbd> close</span>
    </div>
  </div>
</div>

<script>
  function initShell() {
    const dataEl = document.getElementById('shell-data');
    if (!dataEl) return;
    const { routes } = JSON.parse(dataEl.textContent || '{}');

    const palette = document.getElementById('shell-palette');
    const input = document.getElementById('palette-input') as HTMLInputElement | null;
    const completionsEl = document.getElementById('palette-completions');
    if (!palette || !input || !completionsEl) return;

    let isOpen = false;
    let activeIndex = 0;

    interface Completion {
      label: string;
      detail: string;
      kind: 'command' | 'page' | 'post';
      value: string;
      action: () => void;
    }

    let completions: Completion[] = [];

    interface Command {
      name: string;
      describe: () => string;
      complete: (args: string) => Completion[];
      execute: (args: string) => void;
    }

    function fuzzy(query: string, text: string): boolean {
      if (!query) return true;
      const q = query.toLowerCase();
      const t = text.toLowerCase();
      let qi = 0;
      for (let ti = 0; ti < t.length && qi < q.length; ti++) {
        if (t[ti] === q[qi]) qi++;
      }
      return qi === q.length;
    }

    function nav(path: string) {
      close();
      window.location.href = path;
    }

    const commands: Command[] = [
      {
        name: 'cd',
        describe: () => 'Navigate to a page or post',
        complete(args: string): Completion[] {
          return routes
            .filter((r: any) => fuzzy(args, r.label) || fuzzy(args, r.path))
            .map((r: any) => ({
              label: r.type === 'page' ? r.label + '/' : r.label,
              detail: r.path === '/' ? '~' : r.path,
              kind: r.type === 'page' ? 'page' : 'post',
              value: `cd ${r.path}`,
              action: () => nav(r.path),
            }));
        },
        execute(args: string) {
          const exact = routes.find((r: any) => r.path === args || r.label === args.toLowerCase());
          if (exact) return nav(exact.path);
          const matches = routes.filter((r: any) => fuzzy(args, r.label) || fuzzy(args, r.path));
          if (matches.length === 1) return nav(matches[0].path);
          input.classList.add('shake');
          setTimeout(() => input.classList.remove('shake'), 300);
        },
      },
      {
        name: 'ls',
        describe: () => 'List pages or posts',
        complete(args: string): Completion[] {
          const sections: Completion[] = [
            { label: 'pages', detail: 'List all pages', value: 'ls pages', kind: 'command', action: () => setInput('ls pages') },
            { label: 'posts', detail: 'List all posts', value: 'ls posts', kind: 'command', action: () => setInput('ls posts') },
          ];
          return sections.filter(s => fuzzy(args, s.label));
        },
        execute(args: string) {
          if (args.trim().toLowerCase() === 'posts') nav('/writing');
          else {
            showCompletions(routes.filter((r: any) => r.type === 'page').map((r: any) => ({
              label: r.label + '/', detail: r.path, kind: 'page' as const,
              value: `cd ${r.path}`, action: () => nav(r.path),
            })));
          }
        },
      },
      {
        name: 'help',
        describe: () => 'Show available commands',
        complete(): Completion[] {
          return commands.map(c => ({
            label: c.name, detail: c.describe(), kind: 'command' as const,
            value: c.name + ' ', action: () => setInput(c.name + ' '),
          }));
        },
        execute() {
          showCompletions(commands.map(c => ({
            label: c.name, detail: c.describe(), kind: 'command' as const,
            value: c.name + ' ', action: () => setInput(c.name + ' '),
          })));
        },
      },
    ];

    function setInput(val: string) {
      input.value = val;
      input.focus();
      onInput();
    }

    function parseInput(raw: string): { cmd: string; args: string } {
      const trimmed = raw.trim();
      const space = trimmed.indexOf(' ');
      if (space === -1) return { cmd: trimmed, args: '' };
      return { cmd: trimmed.slice(0, space), args: trimmed.slice(space + 1) };
    }

    function getCompletions(raw: string): Completion[] {
      const { cmd, args } = parseInput(raw);
      const hasSpace = raw.includes(' ');

      if (!raw.trim()) {
        return commands.map(c => ({
          label: c.name, detail: c.describe(), kind: 'command' as const,
          value: c.name + ' ', action: () => setInput(c.name + ' '),
        }));
      }

      if (hasSpace) {
        const command = commands.find(c => c.name === cmd);
        if (command) return command.complete(args);
      }

      const matchingCmds: Completion[] = commands
        .filter(c => fuzzy(cmd, c.name))
        .map(c => ({
          label: c.name, detail: c.describe(), kind: 'command' as const,
          value: c.name + ' ', action: () => setInput(c.name + ' '),
        }));

      const matchingRoutes: Completion[] = routes
        .filter((r: any) => fuzzy(cmd, r.label) || fuzzy(cmd, r.path))
        .map((r: any) => ({
          label: r.type === 'page' ? r.label + '/' : r.label,
          detail: r.path === '/' ? '~' : r.path,
          kind: (r.type === 'page' ? 'page' : 'post') as 'page' | 'post',
          value: `cd ${r.path}`, action: () => nav(r.path),
        }));

      const results = [...matchingCmds, ...matchingRoutes];
      if (results.length > 0) return results;

      return [{
        label: 'no matches', detail: 'try "help"', kind: 'command' as const,
        value: 'help', action: () => setInput('help'),
      }];
    }

    function showCompletions(items: Completion[]) {
      completions = items;
      activeIndex = 0;
      render();
    }

    function kindColor(kind: string): string {
      switch (kind) {
        case 'command': return '#bd93f9';  // purple
        case 'page':    return '#50fa7b';  // green
        case 'post':    return '#f1fa8c';  // yellow
        default:        return '#6272a4';
      }
    }

    function kindPrefix(kind: string): string {
      switch (kind) {
        case 'command': return '$';
        case 'page':    return '~/';
        case 'post':    return '📝';
        default:        return '';
      }
    }

    function render() {
      let html = '';
      let lastKind = '';

      completions.forEach((c, i) => {
        // Section divider between kinds
        if (c.kind !== lastKind && lastKind !== '') {
          html += '<div class="c-divider"></div>';
        }
        lastKind = c.kind;

        const active = i === activeIndex;
        const color = kindColor(c.kind);

        html += `<div class="c-row${active ? ' c-active' : ''}" data-index="${i}">`;
        html +=   `<span class="c-prefix" style="color:${color}">${kindPrefix(c.kind)}</span>`;
        html +=   `<span class="c-label">${c.label}</span>`;
        html +=   `<span class="c-detail">${c.detail}</span>`;
        html += `</div>`;
      });

      completionsEl.innerHTML = html;
      const activeEl = completionsEl.querySelector('.c-active');
      if (activeEl) activeEl.scrollIntoView({ block: 'nearest' });
    }

    function onInput() {
      completions = getCompletions(input.value);
      activeIndex = 0;
      render();
    }

    function execute() {
      if (completions[activeIndex]) {
        completions[activeIndex].action();
        return;
      }
      const { cmd, args } = parseInput(input.value.trim());
      const command = commands.find(c => c.name === cmd);
      if (command) command.execute(args);
      else commands[0].execute(input.value.trim());
    }

    function open() {
      isOpen = true;
      palette.setAttribute('aria-hidden', 'false');
      input.value = '';
      onInput();
      // setTimeout is more reliable than rAF for focus after visibility transition
      setTimeout(() => input.focus({ preventScroll: true }), 50);
    }

    function close() {
      isOpen = false;
      palette.setAttribute('aria-hidden', 'true');
      input.value = '';
      input.blur();
    }

    input.addEventListener('input', onInput);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        isOpen ? close() : open();
        return;
      }

      if (!isOpen) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        close();
      } else if (e.key === 'Tab') {
        e.preventDefault();
        if (completions[activeIndex]) setInput(completions[activeIndex].value);
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (completions.length > 0) {
          activeIndex = (activeIndex + 1) % completions.length;
          render();
        }
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (completions.length > 0) {
          activeIndex = (activeIndex - 1 + completions.length) % completions.length;
          render();
        }
      } else if (e.key === 'Enter') {
        e.preventDefault();
        execute();
      }
    });

    completionsEl.addEventListener('click', (e) => {
      const item = (e.target as HTMLElement).closest('.c-row') as HTMLElement | null;
      if (item?.dataset.index) {
        const idx = parseInt(item.dataset.index);
        if (completions[idx]) completions[idx].action();
      }
    });

    palette.querySelector('.palette-backdrop')?.addEventListener('click', close);
  }

  initShell();
  document.addEventListener('astro:after-swap', initShell);
</script>

<style>
  /* ── Overlay ─────────────────────────────────────────────────── */
  .palette-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    transition: opacity 0.15s, visibility 0.15s;
  }
  .palette-overlay[aria-hidden='true'] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .palette-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
  }
  .palette-container {
    position: relative;
    background: #1a1b26;
    border-top: 1px solid #292d3e;
    transform: translateY(0);
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .palette-overlay[aria-hidden='true'] .palette-container {
    transform: translateY(100%);
  }

  /* ── Prompt row (Powerlevel10k style) ────────────────────────── */
  .palette-input-row {
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 0;
    border-bottom: 1px solid #292d3e;
    font-family: var(--font-mono);
    font-size: 14px;
  }
  .prompt {
    display: flex;
    align-items: center;
    gap: 0;
    margin-right: 10px;
    white-space: nowrap;
  }
  .prompt-dir {
    color: #82aaff;
    font-weight: 500;
  }
  .prompt-arrow {
    color: #c792ea;
    margin-left: 8px;
    font-weight: 700;
  }
  .palette-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: #eeffff;
    font-family: var(--font-mono);
    font-size: 14px;
    caret-color: #c792ea;
  }
  .palette-input.shake {
    animation: shake 0.3s ease;
  }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  /* ── Completions (fixed height) ──────────────────────────────── */
  .palette-completions {
    height: 240px;
    overflow-y: auto;
    padding: 8px 8px;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .c-divider {
    height: 1px;
    background: #292d3e;
    margin: 4px 10px;
  }

  .c-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    border-radius: 6px;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: background 0.1s;
  }

  .c-row:hover:not(.c-active) {
    background: rgba(255, 255, 255, 0.03);
  }

  /* ── Active highlight — unmistakable ─────────────────────────── */
  .c-active {
    background: rgba(130, 170, 255, 0.1);
    border-left-color: #82aaff;
  }
  .c-active .c-label {
    color: #eeffff;
  }
  .c-active .c-detail {
    color: #676e95;
  }

  .c-prefix {
    font-weight: 700;
    font-size: 12px;
    width: 24px;
    text-align: center;
    flex-shrink: 0;
  }

  .c-label {
    color: #a6accd;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .c-detail {
    color: #4a5178;
    font-size: 11px;
    flex-shrink: 0;
    text-align: right;
  }

  /* ── Hint bar ────────────────────────────────────────────────── */
  .palette-hint {
    padding: 8px 20px;
    font-size: 10px;
    font-family: var(--font-mono);
    color: #4a5178;
    border-top: 1px solid #292d3e;
    display: flex;
    gap: 16px;
  }
  .palette-hint kbd {
    color: #676e95;
    background: rgba(255, 255, 255, 0.04);
    padding: 1px 5px;
    border-radius: 3px;
    border: 1px solid #292d3e;
    font-size: 10px;
    margin-right: 3px;
  }

  @media (max-width: 640px) {
    .palette-completions { height: 200px; }
  }
</style>
