---
import { getCollection } from 'astro:content';

const posts = await getCollection('writing');
const routes = [
  { path: '/', label: 'home', type: 'page' as const },
  { path: '/about', label: 'about', type: 'page' as const },
  { path: '/writing', label: 'writing', type: 'page' as const },
  { path: '/links', label: 'links', type: 'page' as const },
  ...posts.map(p => ({
    path: `/writing/${p.id}`,
    label: p.data.title,
    type: 'post' as const,
  })),
];
---

<script type="application/json" id="shell-data" set:html={JSON.stringify(routes)} />

<div id="shell-palette" class="palette-overlay" aria-hidden="true">
  <div class="palette-backdrop"></div>
  <div class="palette-container">
    <div class="palette-input-row">
      <span class="prompt">
        <span class="prompt-dir">~/justin.software</span>
        <span class="prompt-arrow">❯</span>
      </span>
      <input
        id="palette-input"
        class="palette-input"
        type="text"
        autocomplete="off"
        spellcheck="false"
        placeholder="cd ..."
      />
    </div>
    <div id="palette-completions" class="palette-completions"></div>
    <div class="palette-hint">
      <span><kbd>↑↓</kbd> select</span>
      <span><kbd>↵</kbd> go</span>
      <span><kbd>esc</kbd> close</span>
    </div>
  </div>
</div>

<script>
  interface Route {
    path: string;
    label: string;
    type: 'page' | 'post';
  }

  function initPalette() {
    const dataEl = document.getElementById('shell-data');
    if (!dataEl) return;
    const routes: Route[] = JSON.parse(dataEl.textContent || '[]');

    const palette = document.getElementById('shell-palette');
    const input = document.getElementById('palette-input') as HTMLInputElement | null;
    const completionsEl = document.getElementById('palette-completions');
    if (!palette || !input || !completionsEl) return;

    let isOpen = false;
    let activeIndex = 0;
    let matches: Route[] = [...routes];

    function fuzzy(query: string, text: string): boolean {
      if (!query) return true;
      const q = query.toLowerCase();
      const t = text.toLowerCase();
      let qi = 0;
      for (let ti = 0; ti < t.length && qi < q.length; ti++) {
        if (t[ti] === q[qi]) qi++;
      }
      return qi === q.length;
    }

    function go(path: string) {
      close();
      const a = document.createElement('a');
      a.href = path;
      a.style.display = 'none';
      document.body.appendChild(a);
      a.click();
      a.remove();
    }

    function filter(query: string) {
      const q = query.replace(/^cd\s+/, '').trim();
      matches = routes.filter(r => fuzzy(q, r.label) || fuzzy(q, r.path));
      activeIndex = 0;
      render();
    }

    function render() {
      let html = '';
      let lastType = '';

      matches.forEach((r, i) => {
        if (r.type !== lastType && lastType !== '') {
          html += '<div class="sh-divider"></div>';
        }
        lastType = r.type;

        const active = i === activeIndex;
        const dotClass = r.type === 'page' ? 'sh-dot-page' : 'sh-dot-post';

        html += `<div class="sh-row${active ? ' sh-active' : ''}" data-index="${i}">
          <span class="sh-dot ${dotClass}"></span>
          <span class="sh-label">${r.label}</span>
          <span class="sh-detail">${r.path}</span>
        </div>`;
      });

      if (!matches.length) {
        html = '<div class="sh-row"><span class="sh-label" style="color:var(--pal-text-faint)">no matches</span></div>';
      }

      completionsEl.innerHTML = html;
      const activeEl = completionsEl.querySelector('.sh-active');
      if (activeEl) activeEl.scrollIntoView({ block: 'nearest' });
    }

    function open() {
      isOpen = true;
      palette.setAttribute('aria-hidden', 'false');
      input.value = '';
      filter('');
      setTimeout(() => input.focus({ preventScroll: true }), 50);
    }

    function close() {
      isOpen = false;
      palette.setAttribute('aria-hidden', 'true');
      input.value = '';
      input.blur();
    }

    input.addEventListener('input', () => filter(input.value));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        isOpen ? close() : open();
        return;
      }

      if (!isOpen) return;

      switch (e.key) {
        case 'Escape':
          e.preventDefault();
          close();
          break;
        case 'ArrowDown':
          e.preventDefault();
          if (matches.length) { activeIndex = (activeIndex + 1) % matches.length; render(); }
          break;
        case 'ArrowUp':
          e.preventDefault();
          if (matches.length) { activeIndex = (activeIndex - 1 + matches.length) % matches.length; render(); }
          break;
        case 'Enter':
          e.preventDefault();
          if (matches[activeIndex]) go(matches[activeIndex].path);
          break;
      }
    });

    completionsEl.addEventListener('click', (e) => {
      const row = (e.target as HTMLElement).closest('.sh-row');
      const idx = row?.getAttribute('data-index');
      if (idx != null && matches[+idx]) go(matches[+idx].path);
    });

    palette.querySelector('.palette-backdrop')?.addEventListener('click', close);
  }

  initPalette();
  document.addEventListener('astro:after-swap', initPalette);
</script>

<style is:global>
  :root {
    --pal-bg: #1a1b26;
    --pal-border: #292d3e;
    --pal-text: #eeffff;
    --pal-text-dim: #a6accd;
    --pal-text-muted: #676e95;
    --pal-text-faint: #4a5178;
    --pal-accent: #82aaff;
    --pal-purple: #c792ea;
    --pal-green: #50fa7b;
    --pal-yellow: #f1fa8c;
    --pal-active-bg: rgba(130, 170, 255, 0.12);
    --pal-hover-bg: rgba(255, 255, 255, 0.03);
  }

  .palette-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    transition: opacity 0.15s, visibility 0.15s;
  }
  .palette-overlay[aria-hidden='true'] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .palette-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
  }
  .palette-container {
    position: relative;
    background: var(--pal-bg);
    border-top: 1px solid var(--pal-border);
    transform: translateY(0);
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .palette-overlay[aria-hidden='true'] .palette-container {
    transform: translateY(100%);
  }

  .palette-input-row {
    padding: 14px 20px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--pal-border);
    font-family: var(--font-mono);
    font-size: 14px;
  }
  .prompt {
    display: flex;
    align-items: center;
    margin-right: 12px;
    white-space: nowrap;
  }
  .prompt-dir { color: var(--pal-accent); font-weight: 500; }
  .prompt-arrow { color: var(--pal-purple); margin-left: 10px; font-weight: 700; font-size: 16px; }
  .palette-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--pal-text);
    font-family: var(--font-mono);
    font-size: 14px;
    caret-color: var(--pal-purple);
  }
  .palette-input::placeholder { color: var(--pal-text-faint); }
  .palette-input.shake { animation: palette-shake 0.3s ease; }
  @keyframes palette-shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  .palette-completions {
    height: 240px;
    overflow-y: auto;
    padding: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .sh-divider { height: 1px; background: var(--pal-border); margin: 6px 12px; }

  .sh-row {
    display: grid;
    grid-template-columns: 12px 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 9px 14px;
    border-radius: 6px;
    cursor: pointer;
    border-left: 3px solid transparent;
    margin: 1px 0;
  }
  .sh-row:hover:not(.sh-active) { background: var(--pal-hover-bg); }
  .sh-active { background: var(--pal-active-bg); border-left-color: var(--pal-accent); }

  .sh-dot { width: 8px; height: 8px; border-radius: 50%; }
  .sh-dot-page { background: var(--pal-green); }
  .sh-dot-post { background: var(--pal-yellow); }

  .sh-label { color: var(--pal-text-dim); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .sh-active .sh-label { color: var(--pal-text); font-weight: 500; }

  .sh-detail { color: var(--pal-text-faint); font-size: 11px; white-space: nowrap; text-align: right; }
  .sh-active .sh-detail { color: var(--pal-text-muted); }

  .palette-hint {
    padding: 8px 20px;
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--pal-text-faint);
    border-top: 1px solid var(--pal-border);
    display: flex;
    gap: 16px;
  }
  .palette-hint kbd {
    color: var(--pal-text-muted);
    background: rgba(255, 255, 255, 0.04);
    padding: 1px 5px;
    border-radius: 3px;
    border: 1px solid var(--pal-border);
    font-size: 10px;
    margin-right: 3px;
  }

  @media (max-width: 640px) {
    .palette-completions { height: 200px; }
  }
</style>
