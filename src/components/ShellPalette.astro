---
import { getCollection } from 'astro:content';

const posts = await getCollection('writing');
const siteData = {
  routes: [
    { path: '/', label: 'home', type: 'page' },
    { path: '/about', label: 'about', type: 'page' },
    { path: '/writing', label: 'writing', type: 'page' },
    { path: '/links', label: 'links', type: 'page' },
    ...posts.map(p => ({
      path: `/writing/${p.id}`,
      label: p.data.title,
      type: 'post',
    })),
  ],
};
---

<script type="application/json" id="shell-data" set:html={JSON.stringify(siteData)} />

<div id="shell-palette" class="palette-overlay" aria-hidden="true">
  <div class="palette-backdrop"></div>
  <div class="palette-container">
    <div class="palette-input-row">
      <span class="palette-prompt">~/justin.software <span class="prompt-dollar">$</span></span>
      <input
        id="palette-input"
        class="palette-input"
        type="text"
        autocomplete="off"
        spellcheck="false"
        autofocus
      />
    </div>
    <div id="palette-completions" class="palette-completions"></div>
    <div class="palette-hint">
      <span><kbd>tab</kbd> complete</span>
      <span><kbd>↑↓</kbd> select</span>
      <span><kbd>↵</kbd> execute</span>
      <span><kbd>esc</kbd> close</span>
    </div>
  </div>
</div>

<script>
  function initShell() {
    const dataEl = document.getElementById('shell-data');
    if (!dataEl) return;
    const { routes } = JSON.parse(dataEl.textContent || '{}');

    const palette = document.getElementById('shell-palette');
    const input = document.getElementById('palette-input') as HTMLInputElement | null;
    const completionsEl = document.getElementById('palette-completions');
    if (!palette || !input || !completionsEl) return;

    let isOpen = false;
    let activeIndex = 0;

    interface Completion {
      label: string;
      detail: string;
      kind: 'command' | 'page' | 'post';
      value: string;
      action: () => void;
    }

    let completions: Completion[] = [];

    interface Command {
      name: string;
      describe: () => string;
      complete: (args: string) => Completion[];
      execute: (args: string) => void;
    }

    function fuzzy(query: string, text: string): boolean {
      if (!query) return true;
      const q = query.toLowerCase();
      const t = text.toLowerCase();
      let qi = 0;
      for (let ti = 0; ti < t.length && qi < q.length; ti++) {
        if (t[ti] === q[qi]) qi++;
      }
      return qi === q.length;
    }

    function nav(path: string) {
      close();
      window.location.href = path;
    }

    const commands: Command[] = [
      {
        name: 'cd',
        describe: () => 'Navigate to a page or post',
        complete(args: string): Completion[] {
          return routes
            .filter((r: any) => fuzzy(args, r.label) || fuzzy(args, r.path))
            .map((r: any) => ({
              label: r.type === 'page' ? r.label + '/' : r.label,
              detail: r.path === '/' ? '~' : r.path,
              kind: r.type === 'page' ? 'page' : 'post',
              value: `cd ${r.path}`,
              action: () => nav(r.path),
            }));
        },
        execute(args: string) {
          const exact = routes.find((r: any) => r.path === args || r.label === args.toLowerCase());
          if (exact) return nav(exact.path);
          const matches = routes.filter((r: any) => fuzzy(args, r.label) || fuzzy(args, r.path));
          if (matches.length === 1) return nav(matches[0].path);
          input.classList.add('shake');
          setTimeout(() => input.classList.remove('shake'), 300);
        },
      },
      {
        name: 'ls',
        describe: () => 'List pages or posts',
        complete(args: string): Completion[] {
          const sections = [
            { label: 'pages', detail: 'List all pages', value: 'ls pages', kind: 'command' as const },
            { label: 'posts', detail: 'List all posts', value: 'ls posts', kind: 'command' as const },
          ];
          return sections
            .filter(s => fuzzy(args, s.label))
            .map(s => ({ ...s, action: () => setInput(s.value) }));
        },
        execute(args: string) {
          if (args.trim().toLowerCase() === 'posts') nav('/writing');
          else {
            showCompletions(routes.filter((r: any) => r.type === 'page').map((r: any) => ({
              label: r.label + '/', detail: r.path, kind: 'page' as const,
              value: `cd ${r.path}`, action: () => nav(r.path),
            })));
          }
        },
      },
      {
        name: 'help',
        describe: () => 'Show available commands',
        complete(): Completion[] {
          return commands.map(c => ({
            label: c.name, detail: c.describe(), kind: 'command' as const,
            value: c.name + ' ', action: () => setInput(c.name + ' '),
          }));
        },
        execute() {
          showCompletions(commands.map(c => ({
            label: c.name, detail: c.describe(), kind: 'command' as const,
            value: c.name + ' ', action: () => setInput(c.name + ' '),
          })));
        },
      },
    ];

    function setInput(val: string) {
      input.value = val;
      input.focus();
      onInput();
    }

    function parseInput(raw: string): { cmd: string; args: string } {
      const trimmed = raw.trim();
      const space = trimmed.indexOf(' ');
      if (space === -1) return { cmd: trimmed, args: '' };
      return { cmd: trimmed.slice(0, space), args: trimmed.slice(space + 1) };
    }

    function getCompletions(raw: string): Completion[] {
      const { cmd, args } = parseInput(raw);
      const hasSpace = raw.includes(' ');

      // No input — show commands only (clean initial state)
      if (!raw.trim()) {
        return commands.map(c => ({
          label: c.name,
          detail: c.describe(),
          kind: 'command' as const,
          value: c.name + ' ',
          action: () => setInput(c.name + ' '),
        }));
      }

      // Has a space — command is locked, delegate to its completer
      if (hasSpace) {
        const command = commands.find(c => c.name === cmd);
        if (command) return command.complete(args);
      }

      // No space — fuzzy match commands + routes simultaneously
      const matchingCmds: Completion[] = commands
        .filter(c => fuzzy(cmd, c.name))
        .map(c => ({
          label: c.name, detail: c.describe(), kind: 'command' as const,
          value: c.name + ' ', action: () => setInput(c.name + ' '),
        }));

      const matchingRoutes: Completion[] = routes
        .filter((r: any) => fuzzy(cmd, r.label) || fuzzy(cmd, r.path))
        .map((r: any) => ({
          label: r.type === 'page' ? r.label + '/' : r.label,
          detail: r.path === '/' ? '~' : r.path,
          kind: (r.type === 'page' ? 'page' : 'post') as 'page' | 'post',
          value: `cd ${r.path}`,
          action: () => nav(r.path),
        }));

      const results = [...matchingCmds, ...matchingRoutes];
      if (results.length > 0) return results;

      return [{
        label: 'no matches', detail: 'try "help"', kind: 'command' as const,
        value: 'help', action: () => setInput('help'),
      }];
    }

    function showCompletions(items: Completion[]) {
      completions = items;
      activeIndex = 0;
      render();
    }

    // ── Rendering ─────────────────────────────────────────────────────

    function kindIcon(kind: string): string {
      switch (kind) {
        case 'command': return '<span class="kind-icon kind-cmd">$</span>';
        case 'page':    return '<span class="kind-icon kind-page">~</span>';
        case 'post':    return '<span class="kind-icon kind-post">✎</span>';
        default:        return '';
      }
    }

    function render() {
      // Group by kind for visual separation
      let html = '';
      let lastKind = '';

      completions.forEach((c, i) => {
        if (c.kind !== lastKind && lastKind !== '') {
          html += '<div class="completion-divider"></div>';
        }
        lastKind = c.kind;

        const active = i === activeIndex;
        html += `<div class="completion${active ? ' active' : ''}" data-index="${i}">
          ${kindIcon(c.kind)}
          <span class="completion-label">${c.label}</span>
          <span class="completion-detail">${c.detail}</span>
        </div>`;
      });

      completionsEl.innerHTML = html;

      // Scroll active into view
      const activeEl = completionsEl.querySelector('.completion.active');
      if (activeEl) activeEl.scrollIntoView({ block: 'nearest' });
    }

    function onInput() {
      completions = getCompletions(input.value);
      activeIndex = 0;
      render();
    }

    function execute() {
      const raw = input.value.trim();
      if (completions[activeIndex]) {
        completions[activeIndex].action();
        return;
      }
      const { cmd, args } = parseInput(raw);
      const command = commands.find(c => c.name === cmd);
      if (command) command.execute(args);
      else commands[0].execute(raw);
    }

    // ── UI ─────────────────────────────────────────────────────────────

    function open() {
      isOpen = true;
      palette.setAttribute('aria-hidden', 'false');
      input.value = '';
      onInput();
      // Double rAF ensures the visibility transition has started before focus
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          input.focus({ preventScroll: true });
        });
      });
    }

    function close() {
      isOpen = false;
      palette.setAttribute('aria-hidden', 'true');
      input.value = '';
      input.blur();
    }

    input.addEventListener('input', onInput);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
        e.preventDefault();
        isOpen ? close() : open();
        return;
      }

      if (!isOpen) return;

      if (e.key === 'Escape') {
        e.preventDefault();
        close();
      } else if (e.key === 'Tab') {
        e.preventDefault();
        if (completions.length > 0) {
          const c = completions[activeIndex];
          if (c) setInput(c.value);
        }
      } else if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (completions.length > 0) {
          activeIndex = (activeIndex + 1) % completions.length;
          render();
        }
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (completions.length > 0) {
          activeIndex = (activeIndex - 1 + completions.length) % completions.length;
          render();
        }
      } else if (e.key === 'Enter') {
        e.preventDefault();
        execute();
      }
    });

    completionsEl.addEventListener('click', (e) => {
      const item = (e.target as HTMLElement).closest('.completion') as HTMLElement | null;
      if (item?.dataset.index) {
        const idx = parseInt(item.dataset.index);
        if (completions[idx]) completions[idx].action();
      }
    });

    palette.querySelector('.palette-backdrop')?.addEventListener('click', close);
  }

  initShell();
  document.addEventListener('astro:after-swap', initShell);
</script>

<style>
  .palette-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    transition: opacity 0.15s, visibility 0.15s;
  }

  .palette-overlay[aria-hidden='true'] {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .palette-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
  }

  .palette-container {
    position: relative;
    background: var(--surface);
    border-top: 1px solid var(--border);
    transform: translateY(0);
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .palette-overlay[aria-hidden='true'] .palette-container {
    transform: translateY(100%);
  }

  .palette-input-row {
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .palette-prompt {
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  .prompt-dollar {
    color: var(--text-secondary);
  }

  .palette-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 13px;
    caret-color: var(--text-secondary);
  }

  .palette-input::placeholder {
    color: var(--text-tertiary);
  }

  .palette-input.shake {
    animation: shake 0.3s ease;
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }

  /* Fixed height completions area — no layout shift */
  .palette-completions {
    padding: 6px 12px;
    font-family: var(--font-mono);
    font-size: 13px;
    height: 240px;
    overflow-y: auto;
  }

  .completion-divider {
    height: 1px;
    background: var(--border);
    margin: 4px 8px;
  }

  .completion {
    padding: 7px 10px;
    display: flex;
    align-items: center;
    border-radius: 4px;
    cursor: pointer;
    gap: 10px;
  }

  .completion.active {
    background: rgba(255, 255, 255, 0.06);
  }

  .completion:hover:not(.active) {
    background: rgba(255, 255, 255, 0.025);
  }

  /* Kind icons — colored badges like ohmyzsh */
  .kind-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    flex-shrink: 0;
  }

  .kind-cmd {
    background: rgba(136, 192, 208, 0.15);
    color: #88c0d0;
  }

  .kind-page {
    background: rgba(163, 190, 140, 0.15);
    color: #a3be8c;
  }

  .kind-post {
    background: rgba(235, 203, 139, 0.15);
    color: #ebcb8b;
  }

  .completion-label {
    color: var(--text-link);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .completion.active .completion-label {
    color: var(--text);
  }

  .completion-detail {
    color: var(--text-tertiary);
    font-size: 11px;
    flex-shrink: 0;
    text-align: right;
  }

  .palette-hint {
    padding: 8px 20px;
    font-size: 10px;
    font-family: var(--font-mono);
    color: var(--text-tertiary);
    border-top: 1px solid var(--border);
    display: flex;
    gap: 16px;
  }

  .palette-hint kbd {
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
    padding: 1px 4px;
    border-radius: 3px;
    border: 1px solid var(--border);
    font-size: 10px;
    margin-right: 3px;
  }

  @media (max-width: 640px) {
    .palette-completions {
      height: 200px;
    }
  }
</style>
