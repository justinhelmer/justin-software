---
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import ShellPalette from '../components/ShellPalette.astro';
import KeyboardNav from '../components/KeyboardNav.astro';
import HelpOverlay from '../components/HelpOverlay.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  subtitle?: string;
}

const {
  title,
  description = 'Justin Helmer — Principal Engineer. Systems architect. Infrastructure builder.',
  subtitle,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | justin.software</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="justin.software" href="/feed.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <ClientRouter />
  </head>
  <body>
    <div class="site">
      <Nav currentPath={Astro.url.pathname} />
      <div class="subheader">
        {subtitle && <p class="mono-label">{subtitle}</p>}
      </div>
      <main transition:animate="fade">
        <slot />
      </main>
    </div>
    <ShellPalette />
    <KeyboardNav />
    <HelpOverlay />
  </body>
</html>

<script>
  import { navigate } from 'astro:transitions/client';
  (window as any).__astro_navigate = navigate;
</script>

<style>
  /*
   * 3-row grid with fixed dimensions:
   *   80px nav (matches Nav component height)
   *   32px subheader (mono-label or empty — never changes)
   *   1fr  content
   */
  .site {
    display: grid;
    grid-template-rows: 80px 32px 1fr;
    min-height: 100vh;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--page-padding);
  }

  .subheader {
    display: flex;
    align-items: flex-end;
    padding-bottom: var(--sp-4);
  }

  main {
    padding-top: var(--sp-6);
    padding-bottom: var(--sp-10);
  }

  @media (max-width: 640px) {
    .site {
      grid-template-rows: 60px 28px 1fr;
    }
  }
</style>
