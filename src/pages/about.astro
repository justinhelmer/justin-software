---
import Base from '../layouts/Base.astro';
---

<Base title="About" description="Justin Helmer — Principal Engineer at Webflow.">
  <h1 class="page-heading">About</h1>
  <img src="/images/justin.svg" alt="Justin Helmer" class="photo" />
  <div class="about-text">
    <p>I'm Justin Helmer. I've been building software for 17 years — the last several at Webflow, where I'm a Principal Engineer working on AI infrastructure and developer tooling.</p>
    <p>Before that: Intellimize, Macy's mobile platform, and a detour through Cal Poly SLO that I never quite finished because the industry kept pulling me in.</p>
    <p>I think in systems and primitives. Most of my work is the kind you never see — the layers underneath that make everything else possible.</p>
  </div>
</Base>

<style>
  .photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    border: 2px solid var(--border);
    margin-bottom: 32px;
    filter: grayscale(100%);
    display: block;
  }

  .about-text {
    max-width: 560px;
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .about-text p + p {
    margin-top: 1.5em;
  }
</style>
