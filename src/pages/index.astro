---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatDate, latestPosts } from '../lib/config';

const posts = await getCollection('writing');
const sorted = latestPosts(posts, 2);
---

<Base title="Home" subtitle="Principal Engineer · Webflow">
  <section class="hero">
    <div class="hero-card">
      <div class="avatar">
        <img src="/images/justin.svg" alt="Justin Helmer" class="avatar-img" />
      </div>
      <div>
        <h1 class="name">Justin Helmer</h1>
        <p class="bio">I build the systems that other engineers build on.</p>
      </div>
    </div>
  </section>

  <section class="latest">
    <p class="mono-label latest-label">Latest</p>
    <div class="latest-grid">
      {sorted.map(post => (
        <a href={`/writing/${post.id}`} class="latest-item">
          <span class="latest-title">{post.data.title}</span>
          <span class="mono-date">{formatDate(post.data.date)}</span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero {
    margin-bottom: 48px;
  }

  .hero-card {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .avatar {
    flex-shrink: 0;
  }

  .avatar-img {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 2px solid var(--border);
  }

  .name {
    font-size: 44px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.05;
    letter-spacing: -2px;
    margin-bottom: 8px;
  }

  .bio {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 500px;
  }

  .latest {
    border-top: 1px solid var(--border);
    padding-top: 24px;
  }

  .latest-label {
    margin-bottom: 16px;
    font-size: 10px;
    letter-spacing: 2px;
  }

  .latest-grid {
    display: flex;
    gap: 40px;
  }

  .latest-item {
    flex: 1;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: color 0.15s;
  }

  .latest-title {
    font-size: 14px;
    color: var(--text-link);
  }

  .latest-item:hover .latest-title {
    color: var(--text);
  }

  @media (max-width: 640px) {
    .name {
      font-size: 32px;
      letter-spacing: -1px;
    }

    .hero-card {
      gap: 16px;
    }

    .avatar-img {
      width: 48px;
      height: 48px;
    }

    .latest-grid {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
