---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatDate, latestPosts } from '../lib/config';

const posts = await getCollection('writing');
const sorted = latestPosts(posts, 2);
---

<Base title="Home" subtitle="Principal Engineer · Webflow">
  <section class="hero">
    <h1 class="name">Justin Helmer</h1>
    <p class="bio">Engineering infrastructure and AI systems at Webflow.</p>
  </section>

  <section class="latest">
    <p class="mono-label latest-label">Latest</p>
    <div class="latest-grid">
      {sorted.map(post => (
        <a href={`/writing/${post.id}`} class="latest-item">
          <span class="latest-title">{post.data.title}</span>
          <span class="mono-date">{formatDate(post.data.date)}</span>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  .hero {
    margin-bottom: var(--sp-12);
  }

  .identity {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
  }

  .photo {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 2px solid var(--border);
    flex-shrink: 0;
  }

  .name {
    font-size: 44px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.05;
    letter-spacing: -2px;
    margin-bottom: var(--sp-3);
  }

  .bio {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 480px;
  }

  .latest {
    border-top: 1px solid var(--border);
    padding-top: var(--sp-6);
  }

  .latest-label {
    margin-bottom: var(--sp-4);
    font-size: 10px;
    letter-spacing: 2px;
  }

  .latest-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
  }

  .latest-item {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    transition: color 0.15s;
  }

  .latest-title {
    font-size: 14px;
    color: var(--text-link);
  }

  .latest-item:hover .latest-title {
    color: var(--text);
  }

  @media (max-width: 640px) {
    .name {
      font-size: 32px;
      letter-spacing: -1px;
    }

    .latest-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-4);
    }
  }
</style>
